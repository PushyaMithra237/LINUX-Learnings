/ - ROOT DIRECTORY
/home/ - STORES ALL PERSONAL FILES
echo$HOME - SHOWS THE HOME DIRECTORY(whatever comes after echo is an argument)
git- FILE COMMAND
mkdir - CREATES A NEW DIRECTORY
mkdir -p -- CREATES MULTIPLE DIRECTORIES IN ONE GO 
mv directory resdirectory --- MOVES FILE FROM ONE DIRECTORY TO ANOTHER
mv --- CAN ALSO BE USED TO RENAME DIRECTORIES 
rm - r -- RECURSIVELY REMOVE CONTENTS OF WHATEVER IS GIVEN 
